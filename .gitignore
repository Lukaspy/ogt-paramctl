# Measurement output (must never be committed; fixtures and examples are explicit allow-listed below)
*.csv
*.h5
*.hdf5
!tests/fixtures/**/*.csv
!tests/fixtures/**/*.h5
!tests/fixtures/**/*.hdf5
!examples/**/*.csv
!examples/**/*.h5
!examples/**/*.hdf5

